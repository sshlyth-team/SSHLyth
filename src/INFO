package="sshlyth"
version="3.0.5-0001"
arch="noarch"
displayname="SSHlyth Client"
maintainer="SSHlyth Dev Team"
firmware="7.0-40000"
startable="yes"
ctl_stop="yes"
thirdparty="yes"
dsmuidir="ui"
dsmappname="SYNO.SDS.sshlyth"
description="SSHlyth is a web-based SSH client for Synology DSM 7. Runs on port 7722 with HTTPS. Access via https://your-nas:7722/ directly, or via https://your-nas/SSHlyth/ after updating nginx redirect setup. To enable nginx access run the following commands (or use DSM Task Scheduler): sudo cp /var/packages/sshlyth/target/nginx-location.conf /etc/nginx/conf.d/dsm.sshlyth.conf && sudo kill -HUP $(cat /run/nginx.pid). Check SSHLyth page to see detailled explanation."
